# Пароль базы данных PostgreSQL.
POSTGRES_PASSWORD=change-me-long-password

# Секрет для подписи токенов входа. Замените на длинную случайную строку.
JWT_SECRET=change-me-random-secret

# Порт API.
API_PORT=8000
INVITE_TOKEN_HOURS=168

# Версия готового Docker-образа при запуске через docker-compose.ghcr.yml.
APP_VERSION=latest
